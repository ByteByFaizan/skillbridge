# NVIDIA NIM (required for AI career analysis — free key at build.nvidia.com)
NVIDIA_API_KEY=

# Supabase (required for auth & persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate Limiting (optional — sensible defaults are built in) ──
# General API: requests per window (default: 100 req / 60 000 ms)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# Auth routes: stricter limits (default: 10 req / 900 000 ms = 15 min)
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ── CORS (comma-separated allowed origins) ──
# Defaults to NEXT_PUBLIC_APP_URL, then http://localhost:3000
# CORS_ALLOWED_ORIGINS=https://skillbridge.example.com,https://staging.skillbridge.example.com

